{
  "version": 2,
  "name": "205-tools-hub",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin/login.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/:path*.html"
    },
    {
      "source": "/tools/:path*",
      "destination": "/tools/:path*.html"
    },
    {
      "source": "/:path*",
      "destination": "/:path*.html"
    }
  ]
}
